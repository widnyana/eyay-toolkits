{
  "description": "Denies git commands that stage protected paths, whole-tree adds, or rewrite history",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/hooks/scripts/block-forbidden-git-add.sh",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
